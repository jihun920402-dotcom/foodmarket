
FROM tomcat:9.0-jdk21-openjdk-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y wget && \
    wget -q "https://repo1.maven.org/maven2/com/mysql/mysql-connector-j/8.3.0/mysql-connector-j-8.3.0.jar" \
    -O /build/mysql-connector-j.jar

COPY src/main/java/ /build/src/
COPY src/main/webapp/WEB-INF/lib/ /build/lib/

RUN mkdir -p /build/classes && \
    find /build/src -name "*.java" > /build/sources.txt && \
    javac -encoding UTF-8 \
          -cp "/usr/local/tomcat/lib/servlet-api.jar:/build/lib/*:/build/mysql-connector-j.jar" \
          -d /build/classes \
          @/build/sources.txt

FROM tomcat:9.0-jdk21-openjdk-slim

RUN rm -rf /usr/local/tomcat/webapps/*

COPY src/main/webapp/ /usr/local/tomcat/webapps/ROOT/
COPY --from=builder /build/classes/ /usr/local/tomcat/webapps/ROOT/WEB-INF/classes/
COPY --from=builder /build/mysql-connector-j.jar /usr/local/tomcat/webapps/ROOT/WEB-INF/lib/

EXPOSE 8080
CMD ["catalina.sh", "run"]
